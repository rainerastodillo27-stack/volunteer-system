SUPABASE_DB_URL=
SUPABASE_DB_URL_FALLBACK=
ALLOWED_ORIGINS=*
DB_STRICT_POSTGRES=true
DB_CONNECT_TIMEOUT=8
DB_CANDIDATE_CONNECT_TIMEOUT=5
DB_CONNECT_MAX_ATTEMPTS=3
DB_CONNECT_RETRY_BASE_MS=400
DB_PROBE_CACHE_TTL_SECONDS=10
DB_FAILOVER_COOLDOWN_SECONDS=15
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
EXPO_PUBLIC_WEB_API_BASE_URL=http://127.0.0.1:8000
VOLCRE_API_BASE_URL=
VOLCRE_WEB_API_BASE_URL=http://127.0.0.1:8000

# Shared database safety:
# Leave these off for normal development, especially when teammates share one database.
VOLCRE_PROTECT_SHARED_DB=true
ENABLE_DEMO_SEED=false
VOLCRE_ALLOW_DEMO_SEED=false
VOLCRE_ALLOW_SCHEMA_SETUP=false
VOLCRE_ALLOW_DEMO_LOGIN_SEED=false
VOLCRE_ALLOW_DB_MIGRATION=false

# Only set these when you intentionally run a one-off database migration.
VOLCRE_OLD_DB_URL=
VOLCRE_NEW_DB_URL=
VOLCRE_OLD_DB_URL_DIRECT=
VOLCRE_NEW_DB_URL_DIRECT=
