# Copy this file to `.env` before running the app locally.
# Keep real secrets in `.env` only and do not commit them.

# Backend database connection used by the FastAPI service and seed scripts.
# Replace YOUR_REAL_PASSWORD with the actual Supabase Postgres password.
# For backend services, prefer the Supabase session pooler on port 5432.
# Example: postgresql://postgres.your-project-ref:YOUR_REAL_PASSWORD@aws-1-region.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:YOUR_REAL_PASSWORD@aws-1-region.pooler.supabase.com:5432/postgres
# Optional explicit fallback if you want to keep a second DSN ready.
SUPABASE_DB_URL_FALLBACK=

# API URLs used by the Expo app.
# For local development, leave VOLCRE_API_BASE_URL blank to use your LAN IP automatically.
# For a hosted backend, set both values to the same HTTPS URL, for example:
# VOLCRE_API_BASE_URL=https://volcre-backend.onrender.com
# VOLCRE_WEB_API_BASE_URL=https://volcre-backend.onrender.com
VOLCRE_API_BASE_URL=
VOLCRE_WEB_API_BASE_URL=http://127.0.0.1:8000

# Optional local development behavior.
# Set VOLCRE_AUTO_START_BACKEND=false when using a hosted backend.
VOLCRE_AUTO_START_BACKEND=true
DB_CONNECT_TIMEOUT=5
DB_CANDIDATE_CONNECT_TIMEOUT=5
DB_FAILOVER_COOLDOWN_SECONDS=120
DB_PROBE_CACHE_TTL_SECONDS=10
ALLOWED_ORIGINS=*

# Optional Google Maps keys.
GOOGLE_MAPS_ANDROID_API_KEY=
GOOGLE_MAPS_WEB_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_WEB_API_KEY=
