{
  "name": "volcre",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "setup:env": "node ./scripts/ensure-env.js",
    "postinstall": "node ./scripts/ensure-env.js",
    "prestart": "node ./scripts/ensure-env.js",
    "preandroid": "node ./scripts/ensure-env.js",
    "preios": "node ./scripts/ensure-env.js",
    "preweb": "node ./scripts/ensure-env.js",
    "prebackend": "node ./scripts/ensure-env.js",
    "prebackend:seed-storage": "node ./scripts/ensure-env.js",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-all.ps1",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-all.ps1",
    "info": "node ./scripts/show-startup-info.js",
    "all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-all.ps1",
    "all:bg": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/supervise-dev.ps1",
    "all:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-all.ps1",
    "all:status": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/status-all.ps1",
    "expo:start": "node ./scripts/start-expo-with-qr.js",
    "expo:web": "expo start --web",
    "expo:android": "expo start --android",
    "expo:ios": "expo start --ios",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "backend": "node ./scripts/run-python.js -m uvicorn backend.api:app --host 0.0.0.0 --port 8000 --ws websockets",
    "backend:seed-storage": "node ./scripts/run-python.js -m backend.app_storage_seed",
    "db:cleanup": "node ./scripts/run-python.js -m backend.database_cleanup",
    "db:cleanup:aggressive": "node ./scripts/run-python.js -m backend.heavy_cleanup",
    "db:cleanup:session": "node ./scripts/run-python.js -m backend.session_cleanup",
    "db:cleanup:batch": "node ./scripts/run-python.js -m backend.batch_cleanup",
    "db:maintenance": "node ./scripts/run-python.js -m backend.database_manager",
    "db:maintenance:report": "node ./scripts/run-python.js -m backend.database_manager --report",
    "db:init": "node ./scripts/run-python.js -m backend.init_supabase"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@jobuntux/psgc": "^0.2.1",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "date-fns": "^3.0.0",
    "expo": "54.0.6",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-location": "~19.0.8",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "^5.3.3"
  },
  "private": true
}
